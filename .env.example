# ---------------------------------------------------------------------------
# Zine — environment variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local`. Only NEXT_PUBLIC_* vars are exposed to the client.
# ---------------------------------------------------------------------------

# --- Supabase (client-safe) ------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (server-only, NEVER expose to the browser) -------------------
# The service role key bypasses Row Level Security. Server-side use only.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Prisma) -----------------------------------------------------
# Supabase Dashboard → Project Settings → Database → Connection string
# Use the pooled connection (port 6543) for the app, direct (5432) for migrations.
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres"

# --- App config ------------------------------------------------------------
# Local dev: http://localhost:3000
# Production (set this in your host's env, e.g. Vercel): https://zine.video
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Storage bucket used for uploaded Zines (create it in Supabase Storage).
NEXT_PUBLIC_SUPABASE_VIDEO_BUCKET="zines"

# Upload limits enforced client + server side
NEXT_PUBLIC_MAX_UPLOAD_MB="50"
NEXT_PUBLIC_MIN_DURATION_SEC="6"
NEXT_PUBLIC_MAX_DURATION_SEC="10"
